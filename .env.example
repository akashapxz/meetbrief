# Google Gemini API Key needed for advanced high-fidelity AI summarizes and Q&A chat grounding
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Supabase Database Integration Settings ---
# Paste your Supabase URI Connection String (e.g. Transaction Pooler or Direct Connection)
# Recommended method: Direct URI or Pooler URI.
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:6543/postgres?sslmode=require

# Alternatively, set individual connection parameters:
SUPABASE_DB_HOST=db.[PROJECT-ID].supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_DB_NAME=postgres

# Firebase Configuration
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
